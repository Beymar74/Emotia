{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "emotia",
    "main": ".open-next/worker.js",
    "compatibility_date": "2026-03-12",
    "observability": {
      "enabled": true
    },
    "compatibility_flags": [
      "nodejs_compat"
    ],
    "assets": {
      "directory": ".open-next/assets",
      "binding": "ASSETS"
    }
  }