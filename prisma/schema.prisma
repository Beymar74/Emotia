generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model audit_log {
  id         BigInt   @id @default(autoincrement())
  actor_id   Int?
  actor_tipo String?  @db.VarChar(20)
  accion     String   @db.VarChar(200)
  detalle    Json?
  ip_address String?  @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([actor_id, actor_tipo], map: "idx_audit_log_actor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model carrito {
  id               Int       @id @default(autoincrement())
  usuario_id       Int
  producto_id      Int
  cantidad         Int       @default(1)
  mensaje_personal String?
  empaque_especial Boolean   @default(false)
  precio_unitario  Decimal   @db.Decimal(10, 2)
  subtotal         Decimal?  @default(dbgenerated("((cantidad)::numeric * precio_unitario)")) @db.Decimal(10, 2)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  productos        productos @relation(fields: [producto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios         usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuario_id, producto_id])
  @@index([usuario_id], map: "idx_carrito_usuario")
}

model categorias {
  id          Int         @id @default(autoincrement())
  nombre      String      @db.VarChar(100)
  descripcion String?
  activo      Boolean     @default(true)
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  productos   productos[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model detalle_pedidos {
  id               Int         @id @default(autoincrement())
  pedido_id        Int
  producto_id      Int
  proveedor_id     Int
  cantidad         Int
  precio_unitario  Decimal     @db.Decimal(10, 2)
  subtotal         Decimal     @db.Decimal(10, 2)
  mensaje_personal String?
  empaque_especial Boolean     @default(false)
  calificacion     Int?        @db.SmallInt
  resena           String?
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  pedidos          pedidos     @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productos        productos   @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  proveedores      proveedores @relation(fields: [proveedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([pedido_id], map: "idx_detalle_pedido")
}

model direcciones {
  id           Int       @id @default(autoincrement())
  usuario_id   Int
  calle        String    @db.VarChar(200)
  numero       String?   @db.VarChar(20)
  zona         String?   @db.VarChar(100)
  referencia   String?
  ciudad       String    @default("La Paz") @db.VarChar(100)
  es_principal Boolean   @default(false)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  usuarios     usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pedidos      pedidos[]
}

model insignias {
  id          Int      @id @default(autoincrement())
  usuario_id  Int
  tipo        String   @db.VarChar(100)
  descripcion String?
  otorgada_en DateTime @default(now()) @db.Timestamptz(6)
  usuarios    usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model notificaciones {
  id         Int      @id @default(autoincrement())
  usuario_id Int
  tipo       String   @db.VarChar(50)
  titulo     String   @db.VarChar(200)
  mensaje    String?
  leida      Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  usuarios   usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id, leida], map: "idx_notificaciones_usuario")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pedidos {
  id               Int               @id @default(autoincrement())
  usuario_id       Int
  direccion_id     Int?
  estado           String            @default("pendiente") @db.VarChar(30)
  subtotal         Decimal           @db.Decimal(12, 2)
  costo_envio      Decimal           @default(0.00) @db.Decimal(10, 2)
  descuento_puntos Decimal           @default(0.00) @db.Decimal(10, 2)
  total            Decimal           @db.Decimal(12, 2)
  puntos_usados    Int               @default(0)
  puntos_ganados   Int               @default(0)
  metodo_pago      String?           @db.VarChar(50)
  referencia_pago  String?           @db.VarChar(150)
  notas            String?
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @default(now()) @db.Timestamptz(6)
  detalle_pedidos  detalle_pedidos[]
  direcciones      direcciones?      @relation(fields: [direccion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios         usuarios          @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([estado], map: "idx_pedidos_estado")
  @@index([usuario_id], map: "idx_pedidos_usuario")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model productos {
  id                  Int               @id @default(autoincrement())
  proveedor_id        Int
  categoria_id        Int?
  nombre              String            @db.VarChar(200)
  descripcion         String?
  precio_base         Decimal           @db.Decimal(10, 2)
  precio_venta        Decimal           @db.Decimal(10, 2)
  stock               Int               @default(0)
  imagen_url          String?
  ocasiones           String[]
  personalidades      String[]
  genero_destinatario String?           @default("cualquiera") @db.VarChar(20)
  edad_min            Int?
  edad_max            Int?
  permite_mensaje     Boolean           @default(true)
  permite_empaque     Boolean           @default(false)
  activo              Boolean           @default(true)
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)
  carrito             carrito[]
  detalle_pedidos     detalle_pedidos[]
  categorias          categorias?       @relation(fields: [categoria_id], references: [id], onUpdate: NoAction)
  proveedores         proveedores       @relation(fields: [proveedor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  recomendaciones     recomendaciones[]

  @@index([activo], map: "idx_productos_activo")
  @@index([categoria_id], map: "idx_productos_categoria")
  @@index([proveedor_id], map: "idx_productos_proveedor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model proveedores {
  id                Int               @id @default(autoincrement())
  nombre_negocio    String            @db.VarChar(150)
  descripcion       String?
  logo_url          String?
  email             String            @unique @db.VarChar(150)
  password_hash     String            @db.VarChar(255)
  telefono          String?           @db.VarChar(20)
  estado            String            @default("pendiente") @db.VarChar(20)
  calificacion_prom Decimal?          @default(0.00) @db.Decimal(3, 2)
  total_vendido     Decimal?          @default(0.00) @db.Decimal(12, 2)
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @db.Timestamptz(6)
  detalle_pedidos   detalle_pedidos[]
  productos         productos[]
}

model recomendaciones {
  id                   Int        @id @default(autoincrement())
  usuario_id           Int
  destinatario_rel     String?    @db.VarChar(100)
  destinatario_edad    Int?
  destinatario_genero  String?    @db.VarChar(20)
  personalidad         String[]
  ocasion              String?    @db.VarChar(100)
  presupuesto_min      Decimal?   @db.Decimal(10, 2)
  presupuesto_max      Decimal?   @db.Decimal(10, 2)
  productos_sugeridos  Int[]
  producto_elegido     Int?
  convertida_en_compra Boolean    @default(false)
  created_at           DateTime   @default(now()) @db.Timestamptz(6)
  productos            productos? @relation(fields: [producto_elegido], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios             usuarios   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id], map: "idx_recomendaciones_usuario")
}

model recordatorios {
  id           Int      @id @default(autoincrement())
  usuario_id   Int
  titulo       String   @db.VarChar(200)
  fecha_evento DateTime @db.Date
  dias_aviso   Int      @default(7)
  descripcion  String?
  activo       Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  usuarios     usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model usuarios {
  id              Int               @id @default(autoincrement())
  nombre          String            @db.VarChar(100)
  apellido        String?           @db.VarChar(100)
  email           String            @unique @db.VarChar(150)
  password_hash   String?           @db.VarChar(255)
  foto_perfil     String?
  telefono        String?           @db.VarChar(20)
  tipo            String            @default("usuario") @db.VarChar(20)
  plan            String            @default("basico") @db.VarChar(20)
  puntos          Int               @default(0)
  google_id       String?           @unique @db.VarChar(100)
  activo          Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  carrito         carrito[]
  direcciones     direcciones[]
  insignias       insignias[]
  notificaciones  notificaciones[]
  pedidos         pedidos[]
  recomendaciones recomendaciones[]
  recordatorios   recordatorios[]
}
